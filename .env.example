# Cursor session cookie value. Get it from your browser:
#   1. Sign in to https://cursor.com
#   2. Open DevTools → Application → Cookies → cursor.com
#   3. Copy the value of `WorkosCursorSessionToken`
# You can paste either just the value, or the full `WorkosCursorSessionToken=...` string.
CURSOR_SESSION_TOKEN=

# Optional. If set, used as a fallback when /api/auth/me cannot be reached.
CURSOR_USER_ID=

# Optional. teamId for get-filtered-usage-events (default 0 = personal, same as Cursor dashboard).
CURSOR_TEAM_ID=0

# Google Chat incoming webhook URL (Space → Apps & integrations → Manage webhooks)
GOOGLE_CHAT_WEBHOOK=

# Public base URL the screenshot script will hit
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Screenshot quality (Playwright + PNG button fallback). Scale 3 ≈ retina; 4 = extra sharp (larger files).
# SCREENSHOT_WIDTH=1920
# SCREENSHOT_SCALE=3

# Optional. Public HTTPS URL of the dashboard PNG (must be reachable without login).
# CI sets this automatically; for private GitHub repos set a Cloudinary/S3 URL here
# and add the same value as the SCREENSHOT_URL repository secret.
SCREENSHOT_URL=

